<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Environmental Dashboard | EcoVision India</title>

    <link rel="stylesheet" href="/static/environmental_dashboard.css">

    <!-- Tableau Embedding API v3 -->
