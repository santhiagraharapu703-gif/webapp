            </p>
        </section>

        <!-- Dashboard Container -->
        <section class="dashboard-container">
            <div class="dashboard-frame">
                <tableau-viz
                    id="tableauViz"
                    src="https://public.tableau.com/views/forest2_17750528742350/Dashboard1?:showVizHome=no"
                    toolbar="bottom"
                    hide-tabs
                    width="100%"
                    height="860">
                </tableau-viz>
            </div>
        </section>

        <!-- Bottom Buttons -->
        <div class="bottom-actions">
            <!-- <a href="/forest-dashboard" class="bottom-btn secondary-btn">🌿 Forest Dashboard</a> -->
