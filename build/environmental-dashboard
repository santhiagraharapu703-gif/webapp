<body>

    <div class="page-wrapper">

        <!-- Top Action -->
        <div class="top-action-bar">
            <a href="/states" class="top-btn">← Back to States</a>
        </div>

        <!-- Hero Banner -->
        <section class="hero-banner">
            <h1>Environmental Analysis Dashboard</h1>
